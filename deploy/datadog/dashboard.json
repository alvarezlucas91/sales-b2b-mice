              {
                "name": "query2",
                "data_source": "metrics",
                "query": "max:kubernetes.memory.limits{$cluster_name,$short_image,$kube_namespace}",
                "aggregator": "max"
              }
            ],
            "conditional_formats": [
              { "comparator": ">=", "palette": "white_on_red", "value": 90 },
              { "comparator": ">", "palette": "white_on_yellow", "value": 80 },
              {
                "comparator": "<=",
                "palette": "custom_bg",
                "value": 30,
                "custom_bg_color": "#83edfb"
              },
              { "comparator": "<=", "value": 80, "palette": "white_on_green" }
            ],
            "formulas": [{ "formula": "(query1 * 100) / query2" }]
          }
        ],
        "autoscale": true,
        "precision": 0,
        "timeseries_background": {
          "yaxis": { "include_zero": false },
          "type": "area"
        }
      },
      "layout": { "x": 0, "y": 8, "width": 4, "height": 2 }
