{
  "title": "${dashboard_name}",
  "description": "Created using the Datadog provider in Terraform",
  "widgets": [
    {
      "id": 2571328601799844,
      "definition": {
        "title": "Last runs over the time",
        "title_size": "16",
        "title_align": "left",
        "show_legend": true,
        "legend_layout": "auto",
        "legend_columns": ["avg", "min", "max", "value", "sum"],
        "time": {},
        "type": "timeseries",
        "requests": [
          {
            "formulas": [{ "alias": "etl", "formula": "query1" }],
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "avg:kubernetes.containers.running{$kube_namespace,$short_image,$cluster_name}"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ]
      },
      "layout": { "x": 0, "y": 0, "width": 8, "height": 2 }
    },
    {
      "id": 558755437262524,
      "definition": {
        "title": "CPU limit vs usage",
        "title_size": "16",
        "title_align": "left",
        "show_legend": true,
        "legend_layout": "auto",
        "legend_columns": ["avg", "min", "max", "value", "sum"],
        "time": {},
        "type": "timeseries",
        "requests": [
          {
            "formulas": [
              {
                "alias": "cpu-limit",
                "style": { "palette": "warm" },
                "formula": "query3"
              },
              {
                "alias": "cpu-usage",
                "style": { "palette": "green" },
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "name": "query3",
                "data_source": "metrics",
                "query": "max:kubernetes.cpu.limits{$kube_namespace,$short_image,$cluster_name} by {pod_name}.rollup(max, 10)"
              },
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "max:kubernetes.cpu.usage.total{$kube_namespace,$short_image,$cluster_name} by {pod_name}.rollup(max, 10)"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "palette": "warm",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ]
      },
      "layout": { "x": 0, "y": 2, "width": 8, "height": 2 }
    },
    {
      "id": 1888202781704576,
      "definition": {
        "title": "Memory limit vs usage",
        "title_size": "16",
        "title_align": "left",
        "show_legend": true,
        "legend_layout": "auto",
        "legend_columns": ["avg", "min", "max", "value", "sum"],
        "time": {},
        "type": "timeseries",
        "requests": [
          {
            "formulas": [
              {
                "alias": "memory-limit",
                "style": { "palette": "dog_classic" },
                "formula": "query1"
              },
              {
                "alias": "memory-usage",
                "style": { "palette": "green" },
                "formula": "query2"
              }
            ],
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "max:kubernetes.memory.limits{$kube_namespace,$short_image,$cluster_name} by {pod_name}.rollup(max, 10)"
              },
              {
                "name": "query2",
                "data_source": "metrics",
                "query": "max:kubernetes.memory.usage{$kube_namespace,$short_image,$cluster_name} by {pod_name}.rollup(max, 10)"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "palette": "cool",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ]
      },
      "layout": { "x": 0, "y": 4, "width": 8, "height": 2 }
    },
    {
      "id": 1813401167629802,
      "definition": {
        "title": "% Memory over-provisioned",
        "title_size": "16",
        "title_align": "left",
        "type": "query_value",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "query2",
                "data_source": "metrics",
                "query": "max:kubernetes.memory.limits{kube_namespace:$kube_namespace.value,short_image:*$short_image.value,$cluster_name}",
                "aggregator": "max"
              },
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "max:kubernetes.memory.usage{kube_namespace:$kube_namespace.value,short_image:*$short_image.value,$cluster_name}",
                "aggregator": "max"
              }
            ],
            "conditional_formats": [
              { "comparator": "<=", "palette": "white_on_green", "value": 30 },
              { "comparator": ">", "palette": "white_on_red", "value": 60 },
              { "comparator": ">", "palette": "white_on_yellow", "value": 30 }
            ],
            "formulas": [{ "formula": "((query2 - query1) * 100) / query2" }]
          }
        ],
        "autoscale": true,
        "precision": 0,
        "timeseries_background": {
          "yaxis": { "include_zero": false },
          "type": "area"
        }
      },
      "layout": { "x": 0, "y": 6, "width": 4, "height": 2 }
    },
    {
      "id": 6562029977587644,
      "definition": {
        "title": "% CPU over-provisioned",
        "title_size": "16",
        "title_align": "left",
        "type": "query_value",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "max:kubernetes.cpu.limits{$kube_namespace,$short_image,$cluster_name}",
                "aggregator": "max"
              },
              {
                "name": "query2",
                "data_source": "metrics",
                "query": "max:kubernetes.cpu.usage.total{$kube_namespace,$short_image,$cluster_name}",
                "aggregator": "max"
              }
            ],
            "conditional_formats": [
              { "comparator": ">", "palette": "white_on_red", "value": 60 },
              { "comparator": ">", "palette": "white_on_yellow", "value": 30 },
              {
                "comparator": "<",
                "palette": "custom_bg",
                "custom_bg_color": "#000000",
                "value": 0
              },
              { "comparator": "<=", "palette": "white_on_green", "value": 30 }
            ],
            "formulas": [
              { "formula": "((query1 - (query2 / 1000000000)) * 100) / query1" }
            ]
          }
        ],
        "autoscale": false,
        "precision": 2,
        "timeseries_background": {
          "yaxis": { "include_zero": false },
          "type": "area"
        }
      },
      "layout": { "x": 4, "y": 6, "width": 4, "height": 2 }
    },
    {
      "id": 802541132376622,
      "definition": {
        "title": "% Memory max usage",
        "title_size": "16",
        "title_align": "left",
        "type": "query_value",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
