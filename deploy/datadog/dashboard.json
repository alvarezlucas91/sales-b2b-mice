    {
      "id": 131478063872644,
      "definition": {
        "title": "Cluster ETL logs",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "response_format": "event_list",
            "query": {
              "data_source": "logs_stream",
              "query_string": "image_name:*$short_image.value $cluster_name $kube_namespace",
              "indexes": [],
              "storage": "hot",
              "sort": { "order": "desc", "column": "timestamp" }
            },
            "columns": [
              { "field": "status_line", "width": "auto" },
              { "field": "timestamp", "width": "auto" },
              { "field": "pod_name", "width": "auto" },
              { "field": "content", "width": "auto" }
            ]
          }
        ],
        "type": "list_stream"
      },
      "layout": { "x": 0, "y": 14, "width": 12, "height": 5 }
    }
  ],
  "template_variables": [
    {
      "name": "cluster_name",
      "prefix": "cluster_name",
      "available_values": ["cluster-k8s", "cluster-k8s-pre", "cluster-k8s-pro"],
      "default": "cluster-k8s-pro"
    },
    {
      "name": "kube_namespace",
      "prefix": "kube_namespace",
      "available_values": ["airflow", "${eks_namespace}"],
      "default": "${eks_namespace}"
    },
    {
      "name": "short_image",
      "prefix": "short_image",
      "available_values": [],
      "default": "${image_name}"
    }
  ],
  "layout_type": "ordered",
  "notify_list": [],
  "reflow_type": "fixed",
  "tags": []
}
